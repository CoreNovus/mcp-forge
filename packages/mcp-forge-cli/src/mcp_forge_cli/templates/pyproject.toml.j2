[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{ server_name }}"
version = "0.1.0"
description = "{{ description }}"
requires-python = "{{ python_requires }}"
{% if author or email %}
authors = [{ name = "{{ author }}"{% if email %}, email = "{{ email }}"{% endif %} }]
{% endif %}
dependencies = [
    "mcp-forge-core>=0.1.0",
    "mcp>=1.0,<2.0",
    "uvicorn[standard]>=0.27.0",
{% for dep in extra_deps %}
    "{{ dep }}",
{% endfor %}
]

[project.optional-dependencies]
dev = [
    "pytest>=7.0",
    "pytest-asyncio>=0.21",
    "ruff>=0.4",
]

[tool.hatch.build.targets.wheel]
packages = ["src/{{ pkg_name }}"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
